# YUCLAW — Environment Configuration
# Copy this to .env and fill in ONE of the two options below

# ── OPTION 1: DGX Spark (local, $0/token, nothing leaves your machine) ──
# Start vLLM first: bash ~/yuclaw/services/start_super.sh
YUCLAW_SUPER_ENDPOINT=http://localhost:8001/v1
YUCLAW_NANO_ENDPOINT=http://localhost:8002/v1

# ── OPTION 2: OpenRouter free API (cloud, still $0/token) ──
# Get free key at: openrouter.ai
# Comment out the DGX lines above, uncomment this:
# OPENROUTER_API_KEY=your_free_key_here

# ── Free data sources (optional — EDGAR and Yahoo Finance work without keys) ──
FRED_API_KEY=
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
